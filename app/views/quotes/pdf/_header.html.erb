<table class='header-table'>
  <tr>
    <td class='logo-cell'>
        <% if organization.id == 2 %>
          <div class='logo-box'>
            <img src='https://bigtreecare.s3.amazonaws.com/public/ShadowRiverLogo.JPG' class='shadow-river-logo'>
          </div>
        <% elsif organization.id == 1 %>
          <div class='logo-box'>
            <img src='https://bigtreecare.s3.amazonaws.com/public/LogoHorizontal.png' class='pdf_header-image'>
          </div>
        <% else %>
          <div class='logo-box'>
            <img src="<%= organization.logo_url %>" class='pdf-logo'>
          </div>
        <% end %>
    </td>
    <td class='address-cell'>
      <div stlye='width: 100%; display: flex; justify-content: end;'>
      <div>
        <span class='company-name'><%= organization.legal_name || organization.name %></span> <br>
        <%= organization.address.street %> <br>
        <%= [organization.address.city, organization.address.postal_code].join(", ") %><br>
        <%= organization.phone_number %>
      </div>
      </div>
    </td>
  </tr>
</table>
