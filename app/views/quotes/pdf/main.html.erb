<% estimate ||= @estimate %>
<% organization ||= estimate.organization %>
<% compressed_view ||= false %>

<div class='alwaysbreak page'>
  <%= render 'quotes/pdf/quote', estimate: estimate, organization: organization, compressed_view: compressed_view %>
</div>

<% unless compressed_view %>
  <%= render 'quotes/pdf/images', estimate: estimate, organization: organization  %>


  <div class='alwaysbreak page'>
    <%= render 'quotes/pdf/details', organization: organization %>
  </div>

  <div class='alwaysbreak page'>
    <%= render 'quotes/pdf/terms', organization: organization %>
  </div>
<% end %>
